// Import a module using different syntaxes

// Basic import name as variable
@import importName;

// Default import
@import 'importName/Path' importVarName;

// Named import
@use 'importName/Path' { namedVar };

import({
	'importName/Path1' = { namedVar1 };
	namedImport;
	'importName/Path2' = namedVar2;
});

Shorthand experimentation that is still safe


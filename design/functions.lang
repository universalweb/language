const sum int = :{
	let a int = 0;
	a++;
	if (a > 10) {
		return a;
	}
}

RAII version
const sum = :{{
	let a int = 0;
	const al = allocator();
	a++;
	if (a > 10) {
		return a;
	}
}}
al.free(); // Automatically called at scope end to free memory

Named scope
const sum = sumScope:(manually set what args can be accessed) {
	let a int = 0;
	function inner(a int) int {
		return a;
	}
	break sumScope inner(a);
}

const contained = sumScope:(manually set what args can be accessed){{
	// No access to outside scope
	// contained entirely to this block
	// RAII applies here
	return 1;
}}


function name () fn(i32) i32 {
	return function(a i32) i32 {
		return a + 1;
	};
}

shorthand version -> Compiler can infer the fn(i32) i32 return type becuase of the return keyword
function name () fn {
	return (a i32) i32 {
		return a + 1;
	};
}

super shorthand -> Infers the entire return
function name () {
	return (a i32) i32 {
		return a + 1;
	};
}
